# PGM-LLM Inference Configuration
# Copy this file to .env and adjust values as needed

# Logging
PGM_VERBOSE=false
PGM_LOG_LEVEL=INFO

# Numerical stability
PGM_EPSILON=1e-10
PGM_USE_LOG_SPACE=false

# Elimination ordering
PGM_DEFAULT_ORDERING_HEURISTIC=min_degree

# LLM settings
PGM_LLM_TIMEOUT=30.0
PGM_LLM_MAX_RETRIES=3

# OpenAI API settings (also works with compatible proxy servers)
PGM_OPENAI_API_KEY=your-api-key-here
PGM_OPENAI_BASE_URL=https://api.openai.com/v1
PGM_OPENAI_MODEL=gpt-4.1o-mini

PGM_LOCAL_URL=http://localhost:1234/v1/chat/completions
PGM_LOCAL_MODEL=qwen2.5-7b-instruct-1m